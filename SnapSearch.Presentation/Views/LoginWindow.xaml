<Window x:Class="SnapSearch.Presentation.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SnapSearch Sign In"
        Width="440" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border CornerRadius="16" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#141929" Offset="0" />
                <GradientStop Color="#1A2035" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="DragBar_MouseDown" />
            <Button Grid.Row="0" Content="&#x2715;" HorizontalAlignment="Right" Margin="0,6,12,0"
                    Width="24" Height="24" FontSize="11" Cursor="Hand"
                    Background="Transparent" BorderThickness="0" Foreground="#565E7A"
                    Click="CloseButton_Click" />

            <StackPanel Grid.Row="1" Margin="48,0,48,40" VerticalAlignment="Center">

                <Border Width="48" Height="48" CornerRadius="12"
                        Background="{StaticResource AccentGradient}"
                        HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="S" Foreground="White" FontSize="24" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <TextBlock Text="SnapSearch" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,4" />
                <TextBlock Text="File Search &amp; Preview System"
                           FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,36" />

                <TextBlock Text="USERNAME" Style="{StaticResource FormLabel}" />
                <TextBox x:Name="UsernameTextBox"
                         Style="{StaticResource SearchTextBox}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Height="40" Margin="0,0,0,16"
                         KeyDown="Input_KeyDown" />

                <TextBlock Text="PASSWORD" Style="{StaticResource FormLabel}" />
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource StyledPasswordBox}"
                             Height="40" Margin="0,0,0,8"
                             KeyDown="PasswordBox_KeyDown" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource DangerBrush}"
                           FontSize="12" Margin="0,4,0,12" TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}" />

                <Button Content="Sign In" Style="{StaticResource PrimaryButton}"
                        Height="44" FontSize="14" Margin="0,8,0,0"
                        Click="LoginButton_Click" />

                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,12,0,0"
                             Background="Transparent" Foreground="{StaticResource AccentBrush}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />

                <TextBlock Text="BABSLAI Release 1.0"
                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,32,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>