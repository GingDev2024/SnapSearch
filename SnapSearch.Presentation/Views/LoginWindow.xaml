<Window x:Name="window" x:Class="SnapSearch.Presentation.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SnapSearch Sign In"
        Width="902" Height="626"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border CornerRadius="16" ClipToBounds="True" Cursor="IBeam" Height="536" VerticalAlignment="Center" Margin="46,0,53,0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="Azure" Offset="0" />
                <GradientStop Color="AliceBlue" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid Margin="0,0,0,10">
            <!-- 🔥 MAIN SPLIT -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 🔹 LEFT SIDE (LOGO / BRANDING) -->
            <Grid Grid.Column="0" Grid.Row="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="335*" />
                    <RowDefinition Height="204*" />
                </Grid.RowDefinitions>
                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,153,0,0" Grid.RowSpan="2">

                    <Border Width="120" Height="120">
                        <Image Source="pack://application:,,,/Resources/snapsearch.png"
                               Stretch="Fill" Margin="-23,-55,-23,10" />
                    </Border>

                    <TextBlock Text="SNAPSEARCH"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#020445"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,0" Height="49" />
                    <TextBlock Text="Find anything. Track everything. Miss nothing."
                        FontSize="23"
                        FontWeight="Bold"
                        FontFamily="Gabriola"
                        Foreground="#020445" />
                </StackPanel>
            </Grid>

            <!-- 🔥 SEPARATOR -->
            <Rectangle Grid.Column="1"
                       Grid.RowSpan="2"
                       Fill="White"
                       Opacity="0.2" />

            <!-- 🔹 RIGHT SIDE (LOGIN FORM) -->
            <StackPanel Grid.Column="2"
                        Grid.Row="1"
                        Margin="6,40,24,0" Height="447" VerticalAlignment="Top">
                <TextBlock Text="LOGIN"
                             FontSize="26"
                             FontWeight="Bold"
                             Foreground="#020445"
                             HorizontalAlignment="Center"
                             Margin="2,20,0,10" />

                <TextBlock Text="Welcome! Find your files quickly and easily."
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="#020445"
                     HorizontalAlignment="Center"
                     Margin="0,10,0,20" />

                <TextBlock Text="USERNAME" Style="{StaticResource FormLabel}" Width="364" Height="25" />
                <TextBox x:Name="UsernameTextBox" Style="{StaticResource SearchTextBox}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Height="40" Width="368"
                         KeyDown="Input_KeyDown" />

                <TextBlock Text="PASSWORD" Style="{StaticResource FormLabel}" Width="366" Height="25" Margin="0,15,0,0" />
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource StyledPasswordBox}"
                             Height="40" Width="368"
                             KeyDown="PasswordBox_KeyDown" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource DangerBrush}"
                           FontSize="11"
                           Margin="10,4,0,12"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}" />

                <Button Content="Sign In"
                        Style="{StaticResource PrimaryButton}"
                        Height="40"
                        Width="368"
                        FontSize="14"
                        Margin="0,15,0,0"
                        Click="LoginButton_Click" />

                <ProgressBar IsIndeterminate="True"
                             Height="7"
                             Margin="0,40,0,0"
                             Background="Transparent"
                             Foreground="{StaticResource SuccessBrush}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />

                <TextBlock Text="BABSLAI Release 1.0"
                           FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,32,0,0" />
            </StackPanel>

            <!-- 🔹 TOP BAR -->
            <Border Grid.Row="0" Grid.ColumnSpan="3"
                    Background="Transparent"
                    MouseLeftButtonDown="DragBar_MouseDown" />

            <Button Grid.Row="0" Grid.ColumnSpan="3"
                    Content="✕"
                    HorizontalAlignment="Right"
                    Margin="0,9,12,3"
                    Width="24"
                    Height="24"
                    FontSize="11"
                    Cursor="Hand"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#565E7A"
                    Click="CloseButton_Click" />
        </Grid>
    </Border>
</Window>