<UserControl x:Class="SnapSearch.Presentation.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:conv="clr-namespace:SnapSearch.Presentation.Common.Converters"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundWindowColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Header -->
            <RowDefinition Height="*" />
            <!-- Body -->
            <RowDefinition Height="Auto" />
            <!-- Footer / status -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             ROW 0 — Page header
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Padding="28,20,28,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Search Files"
                           Style="{StaticResource SectionHeader}" FontSize="20" Margin="0" />
                <TextBlock Grid.Column="0"
                           Text="Locate your files quickly by entering a keyword or using filters such as file name, type, date, or size. Results are displayed instantly for easy access."
                           FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"
                           Margin="1,35,0,0"
                           Foreground="{StaticResource TextMutedBrush}"/>

                <!-- Result count + Export -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,12,0">
                        <Run Text="{Binding TotalResults}" />
                        <Run Text=" results" />
                    </TextBlock>
                    <Button Content="📥 Export CSV"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ExportResultsCommand}"
                            Padding="10,6" FontSize="11"
                            Visibility="{Binding CanExport, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             ROW 1 — Filters + Results
             ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="28,16,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Filters panel ──────────────────────────────── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
                <Border Grid.Column="0" Style="{StaticResource Card}" VerticalAlignment="Stretch">

                    <StackPanel>
                        <TextBlock Text="FILTERS" Style="{StaticResource FormLabel}" />

                        <!-- Keyword with autocomplete -->
                        <TextBlock Text="Keyword" Style="{StaticResource FormLabel}" Margin="0,7,0,4" />
                        <Grid>
                            <StackPanel>
                                <TextBox x:Name="KeywordBox"
                                 Style="{StaticResource SearchTextBox}"
                                 Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewKeyDown="TextBox_PreviewKeyDown"
                                 GotFocus="KeywordBox_GotFocus"
                                 LostFocus="KeywordBox_LostFocus" />

                                <Border Visibility="{Binding ShowSuggestions, Converter={StaticResource BoolToVis}}"
                                Background="White" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="4" Margin="0,-2,0,0"
                                Panel.ZIndex="99">
                                    <ListBox x:Name="SuggestionsListBox"
                                     ItemsSource="{Binding FilteredSuggestions}"
                                     SelectedItem="{Binding SelectedSuggestion}"
                                     BorderThickness="0"
                                     Background="White"
                                     MaxHeight="160"
                                     PreviewMouseDown="SuggestionsList_PreviewMouseDown">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                   FontSize="12" Padding="4,3"
                                                   Foreground="Black" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Directory -->
                        <TextBlock Text="Directory" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource SearchTextBox}"
                             Margin="0,0,7,0"
                             Text="{Binding SearchDirectory, UpdateSourceTrigger=PropertyChanged}"
                             PreviewKeyDown="TextBox_PreviewKeyDown" />
                            <Button Grid.Column="1" Content="💾" Style="{StaticResource PrimaryButton}"
                            Command="{Binding BrowseDirectoryCommand}" FontWeight="Light" Padding="10,8" />
                        </Grid>

                        <!-- Extension -->
                        <TextBlock Text="Extension (e.g. .pdf)" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <TextBox Style="{StaticResource SearchTextBox}"
                         Text="{Binding ExtensionFilter, UpdateSourceTrigger=PropertyChanged}"
                         PreviewKeyDown="TextBox_PreviewKeyDown" />

                        <!-- Date range -->
                        <TextBlock Text="Date Modified From" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <DatePicker Background="{StaticResource SurfaceLightBrush}"
                            Foreground="Black" SelectedDate="{Binding DateMin}" />

                        <TextBlock Text="Date Modified To" Style="{StaticResource FormLabel}" Margin="0,8,0,4" />
                        <DatePicker Background="{StaticResource SurfaceLightBrush}"
                            Foreground="Black" SelectedDate="{Binding DateMax}" />

                        <!-- Size range -->
                        <TextBlock Text="Size Filter (KB) Min KB - Max Kb" Style="{StaticResource FormLabel}" Margin="0,12,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource SearchTextBox}"
                             Text="{Binding SizeMinKb, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                             PreviewKeyDown="TextBox_PreviewKeyDown" />

                            <TextBlock Grid.Column="1" Text="–" VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextMutedBrush}" />

                            <TextBox Grid.Column="2" Style="{StaticResource SearchTextBox}"
                             Text="{Binding SizeMaxKb, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                             PreviewKeyDown="TextBox_PreviewKeyDown" />
                        </Grid>

                        <!-- Buttons -->
                        <Button Content="Search" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SearchCommand}" Height="36" Margin="0,10,0,0" />

                        <Button Content="✕ Cancel Search"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding CancelSearchCommand}"
                                Height="32" Margin="0,6,0,0"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />

                        <Button Content="Clear" Style="{DynamicResource DangerButton}"
                                Command="{Binding ClearCommand}" Height="32" Margin="0,6,0,10" />

                        <!-- Options -->
                        <TextBlock Text="Options" Style="{StaticResource FormLabel}" Margin="0,4,0,8" />
                        <CheckBox Content="Allow Partial Match" Style="{StaticResource StyledCheckBox}"
                                IsChecked="{Binding AllowPartialMatch}" Margin="0,0,0,6" />
                        <CheckBox Content="Search File Contents" Style="{StaticResource StyledCheckBox}"
                                IsChecked="{Binding SearchFileContents}" Margin="0,0,0,6" />
                        <CheckBox Content="Include Subdirectories" Style="{StaticResource StyledCheckBox}"
                                IsChecked="{Binding SearchSubDirectories}" Margin="0,0,0,6" />
                        <CheckBox Content="Regex Keyword" Style="{StaticResource StyledCheckBox}"
                                IsChecked="{Binding UseRegex}" />



                    </StackPanel>
                </Border>
            </ScrollViewer>


            <!-- ── RIGHT: Results panel ──────────────────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <!-- DataGrid -->
                    <RowDefinition Height="Auto" />
                    <!-- Selected file info bar -->
                    <RowDefinition Height="Auto" />
                    <!-- Action buttons + Load More -->
                </Grid.RowDefinitions>

                <!-- DataGrid -->
                <Border Grid.Row="0" Style="{StaticResource Card}" Padding="0">
                    <DataGrid Style="{StaticResource StyledDataGrid}"
                              ColumnHeaderStyle="{StaticResource DataGridColumnHeader}"
                              ItemsSource="{Binding SearchResults}"
                              SelectedItem="{Binding SelectedFile}"
                              MouseDoubleClick="DataGrid_MouseDoubleClick"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="File Name"     Binding="{Binding FileName}"    Width="230" CanUserSort="True" />
                            <DataGridTextColumn Header="Extension"     Binding="{Binding Extension}"   Width="80"  CanUserSort="True" />
                            <DataGridTextColumn Header="Size"          Binding="{Binding SizeDisplay}" Width="80"  CanUserSort="True" />
                            <DataGridTextColumn Header="Last Modified"
                                                Binding="{Binding LastModified, StringFormat='{}{0:MM/dd/yyyy hh:mm tt}'}"
                                                Width="150" CanUserSort="True" />
                            <DataGridTextColumn Header="Matches"       Binding="{Binding ContentMatchCount}" Width="60" CanUserSort="True" />
                            <DataGridTextColumn Header="Path"          Binding="{Binding Directory}"   Width="*"   CanUserSort="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Selected file info bar -->
                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceLightBrush}"
                        Padding="12,6" Margin="0,4,0,0"
                        CornerRadius="6"
                        Visibility="{Binding SelectedFile, Converter={StaticResource NullToVis}}">
                    <TextBlock Text="{Binding SelectedFileInfo}"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                </Border>

                <!-- Bottom action row -->
                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Load More -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Load More Results"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding LoadMoreCommand}"
                                Padding="12,6" Margin="0,0,8,0"
                                Visibility="{Binding HasMoreResults, Converter={StaticResource BoolToVis}}" />
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                                   Visibility="{Binding HasMoreResults, Converter={StaticResource BoolToVis}}">
                            <Run Text="Showing " />
                            <Run Text="{Binding DisplayedResults}" />
                            <Run Text=" of " />
                            <Run Text="{Binding TotalResults}" />
                        </TextBlock>
                    </StackPanel>

                    <!-- Open Preview -->
                    <Button Grid.Column="1" Content="Open Preview"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding OpenFilePreviewCommand}"
                            Visibility="{Binding CanViewFile, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             ROW 2 — Status bar
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="0,3,0,0" Padding="28,8" BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="109*" />
                    <ColumnDefinition Width="205*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusText}" Grid.ColumnSpan="2" />
                <ProgressBar HorizontalAlignment="Left" Width="942"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             Background="Transparent" Foreground="{StaticResource SuccessBrush}" Margin="0,5,0,2" Grid.ColumnSpan="2" />
            </Grid>
        </Border>
    </Grid>
</UserControl>