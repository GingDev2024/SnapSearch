<Window x:Class="SnapSearch.Presentation.Views.FilePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Preview"
        Width="1000" Height="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border CornerRadius="12" ClipToBounds="True" Background="{StaticResource PrimaryBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryLightBrush}"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentFile.FileName}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text=" — " Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding CurrentFile.SizeDisplay}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Match navigation -->
                        <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="6"
                                Padding="8,4" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Prev" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding PreviousMatchCommand}"
                                        Padding="8,2" FontSize="11" />
                                <TextBlock Text="{Binding MatchDisplay}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12" VerticalAlignment="Center" Margin="8,0" />
                                <Button Content="Next" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding NextMatchCommand}"
                                        Padding="8,2" FontSize="11" />
                            </StackPanel>
                        </Border>
                        <Button Content="Print" Style="{StaticResource SecondaryButton}"
                                Command="{Binding PrintCommand}" Padding="10,4" Margin="0,0,6,0"
                                Visibility="{Binding CanPrint, Converter={StaticResource BoolToVis}}" />
                        <Button Content="Export" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ExportCommand}" Padding="10,4" Margin="0,0,6,0"
                                Visibility="{Binding CanExport, Converter={StaticResource BoolToVis}}" />
                        <Button Content="Copy Path" Style="{StaticResource SecondaryButton}"
                                Command="{Binding CopyPathCommand}" Padding="10,4" Margin="0,0,12,0"
                                Visibility="{Binding CanCopy, Converter={StaticResource BoolToVis}}" />
                        <Button Content="X" Width="28" Height="28" FontSize="12"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextMutedBrush}" Cursor="Hand"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <!-- File content viewer -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}">
                    <ScrollViewer x:Name="TextScrollViewer"
                                  Visibility="{Binding IsTextFile, Converter={StaticResource BoolToVis}}"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <RichTextBox x:Name="ContentRichTextBox"
                                     Background="Transparent"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     FontFamily="Consolas" FontSize="12"
                                     IsReadOnly="True"
                                     BorderThickness="0"
                                     Padding="16">
                            <FlowDocument />
                        </RichTextBox>
                    </ScrollViewer>
                </Border>

                <!-- Match List Panel -->
                <Border Grid.Column="1" Background="{StaticResource PrimaryLightBrush}"
                        BorderThickness="1,0,0,0" BorderBrush="{StaticResource BorderBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="12,10"
                                BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="MATCHES "
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding TotalMatches}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding ContentMatches}"
                                 SelectedItem="{Binding SelectedMatch}"
                                 Background="Transparent" BorderThickness="0"
                                 SelectionChanged="MatchList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,8" CornerRadius="6" Margin="4,2"
                                            Background="{StaticResource SurfaceColor}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Ln " FontSize="10"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="Bold" />
                                                <TextBlock Text="{Binding LineNumber}" FontSize="10"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="Bold" />
                                                <TextBlock Text="  Pg " FontSize="10"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                                <TextBlock Text="{Binding PageNumber}" FontSize="10"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding LineContent}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11" TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="2" Padding="16,6" BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource BorderBrush}"
                    Background="{StaticResource PrimaryLightBrush}">
                <Grid>
                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusText}" />
                    <TextBlock HorizontalAlignment="Right"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="10"
                               Text="{Binding CurrentFile.FilePath}"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>