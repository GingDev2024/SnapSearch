<Window x:Class="SnapSearch.Presentation.Views.FilePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SnapSearch.Presentation.Views"
        Title="File Preview"
        Width="1100" Height="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{StaticResource BackgroundWindowColor}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border CornerRadius="0" Background="{StaticResource BackgroundWindowColor}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#FF252C40"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentFile.FileName}"
                                   Foreground="White" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <TextBlock Text=" — " Foreground="White" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding CurrentFile.SizeDisplay}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="#BBE2FC" CornerRadius="6" Padding="8,4" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Prev" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding PreviousMatchCommand}" Padding="8,2" FontSize="11" />
                                <TextBlock Text="{Binding MatchDisplay}" Foreground="Black"
                                           FontSize="12" VerticalAlignment="Center" Margin="8,0" />
                                <Button Content="Next" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding NextMatchCommand}" Padding="8,2" FontSize="11" />
                            </StackPanel>
                        </Border>
                        <Button Content="Print" Style="{StaticResource PrimaryButton}"
                                Command="{Binding PrintCommand}" Padding="10,4" Margin="0,0,6,0"
                                Visibility="{Binding CanPrint, Converter={StaticResource BoolToVis}}" />
                        <Button Content="Export" Style="{StaticResource PrimaryButton}"
                                Command="{Binding ExportCommand}" Padding="10,4" Margin="0,0,6,0"
                                Visibility="{Binding CanExport, Converter={StaticResource BoolToVis}}" />
                        <Button Content="Copy Path" Style="{StaticResource PrimaryButton}"
                                Command="{Binding CopyPathCommand}" Padding="10,4" Margin="0,0,12,0"
                                Visibility="{Binding CanCopy, Converter={StaticResource BoolToVis}}" />
                        <Button Content="X" Width="28" Height="28" FontSize="12"
                                Background="#FF252C40" BorderThickness="0"
                                Foreground="{StaticResource DangerBrush}" Cursor="Hand"
                                Click="CloseButton_Click" FontWeight="Bold" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content area — must stretch to fill Row 1 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <!-- Left: file viewers — stretch vertically -->
                <Border Grid.Column="0"
                        Background="{StaticResource BackgroundWindowColor}"
                        VerticalAlignment="Stretch">
                    <Grid VerticalAlignment="Stretch">

                        <!-- 1. Text / code files -->
                        <ScrollViewer x:Name="TextScrollViewer"
                                      Visibility="{Binding IsTextFile, Converter={StaticResource BoolToVis}}"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      Background="{StaticResource BackgroundWindowColor}">
                            <RichTextBox x:Name="ContentRichTextBox"
                                         Background="{StaticResource BackgroundWindowColor}"
                                         Foreground="Black"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Padding="16"
                                         AcceptsReturn="True">
                                <RichTextBox.Document>
                                    <FlowDocument PagePadding="4,0,4,0"
                                                  PageWidth="10000"
                                                  TextAlignment="Left"
                                                  FontFamily="Consolas"
                                                  FontSize="13" />
                                </RichTextBox.Document>
                            </RichTextBox>
                        </ScrollViewer>

                        <!-- 2. PDF files -->
                        <views:PdfViewerControl x:Name="PdfViewer"
                                                Visibility="{Binding IsPdfFile, Converter={StaticResource BoolToVis}}" />

                        <!-- 3. Image files -->
                        <ScrollViewer Visibility="{Binding IsImageFile, Converter={StaticResource BoolToVis}}"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <Image x:Name="PreviewImage"
                                   Stretch="Uniform" Margin="16"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </ScrollViewer>

                        <!-- 4. DOCX files -->
                        <Grid Visibility="{Binding IsDocxFile, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- DOCX header bar -->
                            <Border Grid.Row="0" Background="{StaticResource SurfaceLightBrush}"
                                    Padding="16,8" BorderThickness="0,0,0,1"
                                    BorderBrush="{StaticResource BorderBrush}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📄" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="White" />
                                    <TextBlock Text="Word Document Preview"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- DOCX text content -->
                            <ScrollViewer Grid.Row="1"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          Background="White">
                                <RichTextBox x:Name="DocxRichTextBox"
                                             Background="White"
                                             Foreground="Black"
                                             FontFamily="Segoe UI"
                                             FontSize="13"
                                             IsReadOnly="True"
                                             BorderThickness="0"
                                             Padding="32,24"
                                             AcceptsReturn="True">
                                    <RichTextBox.Document>
                                        <FlowDocument PagePadding="4,0,4,0"
                                                      TextAlignment="Left"
                                                      FontFamily="Segoe UI"
                                                      FontSize="13" />
                                    </RichTextBox.Document>
                                </RichTextBox>
                            </ScrollViewer>
                        </Grid>

                        <!-- 5. XLSX files -->
                        <Grid Visibility="{Binding IsXlsxFile, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <!-- Row 0: header bar — fixed -->
                                <RowDefinition Height="36" />
                                <!-- Row 1: sheet tabs — fixed -->
                                <RowDefinition Height="*" />
                                <!-- Row 2: DataGrid — fills rest -->
                            </Grid.RowDefinitions>

                            <!-- XLSX header bar -->
                            <Border Grid.Row="0"
                                    Background="{StaticResource SurfaceLightBrush}"
                                    Padding="16,8"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{StaticResource BorderBrush}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊"
                                               FontSize="14"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="Spreadsheet Preview"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <ScrollViewer Grid.Row="1"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Background="{StaticResource SurfaceLightBrush}">
                                <ItemsControl ItemsSource="{Binding XlsxSheetNames}">

                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>

                                            <Button Content="{Binding}"
                                                    Command="{Binding DataContext.SelectSheetCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Padding="14,4"
                                                    Margin="2,2,0,2"
                                                    FontSize="11" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- XLSX DataGrid — fills all remaining height -->

                            <DataGrid Grid.Row="2"
                                      x:Name="XlsxDataGrid"

                                      AutoGenerateColumns="True"
                                      AutoGeneratingColumn="XlsxDataGrid_AutoGeneratingColumn"

                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeColumns="True"
                                      CanUserResizeRows="True"
                                      CanUserSortColumns="True"

                                      SelectionMode="Extended"
                                      SelectionUnit="Cell"

                                      GridLinesVisibility="All"
                                      HorizontalGridLinesBrush="#E0E0E0"
                                      VerticalGridLinesBrush="#E0E0E0"

                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"

                                      EnableColumnVirtualization="True"
                                      EnableRowVirtualization="True"

                                      Background="White"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F5F8FF"
                                      BorderThickness="0"

                                      FontSize="12"
                                      FontFamily="Segoe UI"
                                      RowHeight="28"
                                      ColumnHeaderHeight="32"

                                      ColumnHeaderStyle="{StaticResource DataGridColumnHeader}"
                                      Style="{StaticResource StyledDataGrid}">

                                <!-- ── Row appearance ────────────────────────────────── -->
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="FontSize"   Value="12" />
                                        <Setter Property="FontFamily" Value="Segoe UI" />

                                        <Style.Triggers>
                                            <!-- Selected row: blue highlight, keep text readable -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#CCE5FF" />
                                                <Setter Property="Foreground" Value="Black" />
                                            </Trigger>

                                            <!-- Hover row: subtle highlight -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#EAF4FF" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                            </DataGrid>
                        </Grid>

                        <!-- 6. Unsupported files -->
                        <StackPanel Visibility="{Binding IsUnsupportedFile, Converter={StaticResource BoolToVis}}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="⚠" FontSize="48" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock Text="Preview not available for this file type"
                                       FontSize="14" Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center" Margin="0,12,0,0" />
                            <TextBlock Text="{Binding CurrentFile.Extension}"
                                       FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0" />
                            <Button Content="Open with Default App"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,20,0,0" Padding="16,8"
                                    Click="OpenWithDefaultApp_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Right: matches panel -->
                <Border Grid.Column="1" Background="{StaticResource PrimaryLightBrush}"
                        BorderThickness="1,0,0,0" BorderBrush="{StaticResource BorderBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="12,10"
                                BorderThickness="0,0,0,1" BorderBrush="#FF252C40" Background="#FF252C40">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="MATCHES " Foreground="White"
                                           FontSize="11" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding TotalMatches}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="12" FontWeight="Bold" Margin="4,0,0,0" />
                            </StackPanel>
                        </Border>
                        <ListBox Grid.Row="1" ItemsSource="{Binding ContentMatches}"
                                 SelectedItem="{Binding SelectedMatch}"
                                 Background="{StaticResource BackgroundWindowColor}" BorderThickness="0"
                                 SelectionChanged="MatchList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,8" CornerRadius="6" Margin="4,2"
                                            Background="{StaticResource SurfaceBrush}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Line " FontSize="10"
                                                           Foreground="{StaticResource AccentBrush}" FontWeight="Bold" />
                                                <TextBlock Text="{Binding LineNumber}" FontSize="10"
                                                           Foreground="{StaticResource AccentBrush}" FontWeight="Bold" />
                                                <TextBlock Text="  Pg " FontSize="10"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                                <TextBlock Text="{Binding PageNumber}" FontSize="10"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding LineContent}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11" TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <!-- Status bar -->
            <Border Grid.Row="2" Padding="16,6" BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource BorderBrush}"
                    Background="{StaticResource BackgroundWindowColor}">
                <Grid>
                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusText}" />
                    <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource TextMutedBrush}"
                               FontSize="12" Text="{Binding CurrentFile.FilePath}"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>