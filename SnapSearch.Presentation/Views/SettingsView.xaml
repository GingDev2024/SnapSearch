<UserControl x:Class="SnapSearch.Presentation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundWindowColor}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="28,20,28,0">
            <TextBlock Text="Settings"
                       Style="{StaticResource SectionHeader}"
                       FontSize="20" />

            <TextBlock Text="Customize your search defaults, result limits, security settings, and more."
                       FontSize="12"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Margin="0,6,0,20" />
        </StackPanel>

        <!-- Scrollable Body -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel Margin="28,0,28,28"
                        MaxWidth="720">

                <!-- Loading -->
                <ProgressBar Height="8"
                             IsIndeterminate="True"
                             Background="Transparent"
                             Foreground="{StaticResource SuccessBrush}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             Margin="0,0,0,16"/>

                <!-- DEFAULT DIRECTORY -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="DEFAULT SEARCH DIRECTORY"
                                   Style="{StaticResource FormLabel}" />

                        <TextBlock Text="The folder SnapSearch opens by default when searching."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Style="{StaticResource SearchTextBox}"
                                     Text="{Binding DefaultDirectory}" />

                            <Button Grid.Column="2"
                                    Content="Browse"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding BrowseDirectoryCommand}"
                                    Padding="14,8"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- SEARCH DEFAULTS -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="SEARCH DEFAULTS"
                                   Style="{StaticResource FormLabel}"
                                   Margin="0,0,0,12"/>

                        <CheckBox Content="Search subdirectories by default"
                                  Style="{StaticResource StyledCheckBox}"
                                  IsChecked="{Binding SearchSubDirectoriesByDefault}"
                                  Margin="0,0,0,10"/>

                        <CheckBox Content="Search file contents by default"
                                  Style="{StaticResource StyledCheckBox}"
                                  IsChecked="{Binding SearchContentsDefault}"
                                  Margin="0,0,0,10"/>

                        <CheckBox Content="Allow partial keyword matching by default"
                                  Style="{StaticResource StyledCheckBox}"
                                  IsChecked="{Binding AllowPartialMatchDefault}"
                                  Margin="0,0,0,10"/>

                        <CheckBox Content="Use regex keyword matching by default"
                                  Style="{StaticResource StyledCheckBox}"
                                  IsChecked="{Binding UseRegexDefault}"/>
                    </StackPanel>
                </Border>

                <!-- SIZE FILTER -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>

                        <TextBlock Text="DEFAULT FILE SIZE FILTER (KB)"
                                   Style="{StaticResource FormLabel}"
                                   Margin="0,0,0,4"/>

                        <TextBlock Text="Leave blank for no limit. Example: min=100, max=10240 (10 MB)."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Min KB"
                                           Style="{StaticResource FormLabel}"
                                           Margin="0,0,0,4"/>

                                <TextBox Style="{StaticResource SearchTextBox}"
                                         Text="{Binding SizeMinKbDefault}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Max KB"
                                           Style="{StaticResource FormLabel}"
                                           Margin="0,0,0,4"/>

                                <TextBox Style="{StaticResource SearchTextBox}"
                                         Text="{Binding SizeMaxKbDefault}" />
                            </StackPanel>

                        </Grid>

                    </StackPanel>
                </Border>

                <!-- RESULT DISPLAY -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>

                        <TextBlock Text="RESULT DISPLAY"
                                   Style="{StaticResource FormLabel}"
                                   Margin="0,0,0,4"/>

                        <TextBox Style="{StaticResource SearchTextBox}"
                                 Width="200"
                                 Text="{Binding MaxResultsPerPage}" />

                    </StackPanel>
                </Border>

                <!-- SESSION -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>

                        <TextBlock Text="SESSION SECURITY"
                                   Style="{StaticResource FormLabel}"
                                   Margin="0,0,0,12"/>

                        <CheckBox Content="Enable auto-logout"
                                  Style="{StaticResource StyledCheckBox}"
                                  IsChecked="{Binding EnableSessionTimeout}"
                                  Margin="0,0,0,10"/>

                        <TextBox Style="{StaticResource SearchTextBox}"
                                 Width="200"
                                 Text="{Binding SessionTimeoutMinutes}" />

                    </StackPanel>
                </Border>

                <!-- SAVE -->
                <StackPanel Orientation="Horizontal" Margin="0,10,0,30">
                    <Button Content="Save Settings"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveSettingsCommand}"
                            Padding="20,10"/>

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource SuccessBrush}"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"/>
                </StackPanel>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</UserControl>