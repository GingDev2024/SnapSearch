<UserControl x:Class="SnapSearch.Presentation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Background="{StaticResource PrimaryBrush}" Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" Style="{StaticResource SectionHeader}" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="600" HorizontalAlignment="Left">

                <!-- Default Directory -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="DEFAULT SEARCH DIRECTORY" Style="{StaticResource FormLabel}" />
                        <TextBlock Text="The folder SnapSearch opens by default when searching."
                                   Foreground="AliceBlue" FontSize="11"
                                   Margin="0,0,0,10" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource SearchTextBox}"
                                     Text="{Binding DefaultDirectory, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2" Content="Browse" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding BrowseDirectoryCommand}" Padding="14,8" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Search Defaults -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="SEARCH DEFAULTS" Style="{StaticResource FormLabel}" Margin="0,0,0,12" />

                        <CheckBox Content="Search subdirectories by default"
                                  Style="{StaticResource StyledCheckBox}"
                                  IsChecked="{Binding SearchSubDirectoriesByDefault}"
                                  Margin="0,0,0,10" />

                        <CheckBox Content="Search file contents by default"
                                  Style="{StaticResource StyledCheckBox}"
                                  IsChecked="{Binding SearchContentsDefault}"
                                  Margin="0,0,0,10" />

                        <CheckBox Content="Allow partial keyword matching by default"
                                  Style="{StaticResource StyledCheckBox}"
                                  IsChecked="{Binding AllowPartialMatchDefault}" />
                    </StackPanel>
                </Border>

                <!-- Application Info -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="APPLICATION INFO" Style="{StaticResource FormLabel}" Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Application"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="BABSLAI — SnapSearch"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Release"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="1.0"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Platform"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text=".NET 8 / WPF"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Save Button -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="Save Settings" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveSettingsCommand}" Padding="20,10" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource SuccessBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0" FontSize="12" />
                </StackPanel>

                <ProgressBar Height="3" Margin="0,12,0,0"
                             IsIndeterminate="True" Background="Transparent"
                             Foreground="{StaticResource AccentBrush}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>