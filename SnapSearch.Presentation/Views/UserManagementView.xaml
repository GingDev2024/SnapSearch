<UserControl x:Class="SnapSearch.Presentation.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundWindowColor}" Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,17">
                <TextBlock Text="User Management" 
                           Style="{StaticResource SectionHeader}" 
                           FontSize="20"
                           Margin="4,0,0,0" />
                <TextBlock Text="Handle user accounts efficiently by adding new users, editing details, and managing roles and permissions."
                          Margin="4,25,0,0"
                           FontSize="12"
                           FontWeight="SemiBold" />

                <!--<Button Content="+ New User" Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Right" Command="{Binding NewUserCommand}" Padding="12,6" />-->
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                <DataGrid Style="{StaticResource StyledDataGrid}"
                          ColumnHeaderStyle="{StaticResource DataGridColumnHeader}"
                          ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="190" CanUserSort="True"/>
                        <DataGridTextColumn Header="Role"     Binding="{Binding Role}"     Width="190" CanUserSort="True"/>
                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="130" />
                        <DataGridTextColumn Header="Created"
                                            Binding="{Binding CreatedAt, StringFormat='{}{0:MM/dd/yyyy hh:mm tt}'}"
                                            Width="*" CanUserSort="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Border Grid.Column="2" Style="{StaticResource Card}" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Margin="0,0,0,16">
                    <Run Text="{Binding IsEditing, Mode=OneWay, Converter={StaticResource EditLabelConverter}}" />
                </TextBlock>

                <TextBlock Text="USERNAME" Style="{StaticResource FormLabel}" />
                <TextBox Style="{StaticResource SearchTextBox}"
                         Text="{Binding FormUsername, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" />

                <TextBlock Text="ROLE" Style="{StaticResource FormLabel}" />
                <ComboBox Style="{StaticResource StyledComboBox}"
                          ItemsSource="{Binding Roles}" Foreground="Black"
                          SelectedItem="{Binding FormRole}" Margin="0,0,0,12" />

                <TextBlock Text="PASSWORD (leave blank to keep)" Style="{StaticResource FormLabel}" />
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource StyledPasswordBox}"
                             Margin="0,0,0,12" PasswordChanged="PasswordBox_PasswordChanged" />

                <CheckBox Content="Active" Style="{StaticResource StyledCheckBox}"
                          IsChecked="{Binding FormIsActive}" Margin="0,0,0,20" />

                <StackPanel Orientation="Horizontal">
                    <Button Content="Save" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveUserCommand}" Margin="0,0,8,0" Padding="20,8" />
                    <Button Content="Delete / Deactivate" Style="{StaticResource DangerButton}"
                            Command="{Binding DeleteUserCommand}" Padding="12,8"
                            Visibility="{Binding IsEditing, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusText}"
                           Margin="0,12,0,0" Foreground="{StaticResource SuccessBrush}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>