<Window x:Class="SnapSearch.Presentation.Views.MainShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SnapSearch.Presentation.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:view="clr-namespace:SnapSearch.Presentation.Views"
        Title="BABSLAI SnapSearch"
        Width="1280" Height="750"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        Background="{StaticResource BackgroundWindowColor}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <DataTemplate DataType="{x:Type vm:SearchViewModel}">
            <view:SearchView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UserManagementViewModel}">
            <view:UserManagementView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AccessLogViewModel}">
            <view:AccessLogView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <view:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="12" ClipToBounds="True">
        <Border.Background>
            <SolidColorBrush Color="Azure" />
        </Border.Background>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="{StaticResource BackgroundWindowColor}"
                    BorderThickness="0,0,1,0" BorderBrush="Transparent">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Logo + Title bar -->
                    <Grid Grid.Row="0" Height="56" Background="{StaticResource BackgroundWindowColor}"
                          MouseLeftButtonDown="TitleBar_MouseDown">
                        <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="50">
                                <Image Source="pack://application:,,,/Resources/snapsearch.png"
                                       Stretch="Uniform" Margin="2,1,0,0" />
                            </Border>
                            <TextBlock Text="SnapSearch" Foreground="Black"
                                       FontSize="16" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="10,0,0,0" />
                        </StackPanel>
                        <!-- Window buttons -->
                        <!--<StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Margin="0,0,8,0">
                            <Button Content="&#x2014;" Width="22" Height="22" FontSize="10"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextMutedBrush}" Cursor="Hand"
                                    Click="MinimizeButton_Click" />
                            <Button Content="&#x2715;" Width="22" Height="22" FontSize="10"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextMutedBrush}" Cursor="Hand"
                                    Click="CloseButton_Click" />
                        </StackPanel>-->
                    </Grid>

                    <!-- Navigation -->
                    <StackPanel Grid.Row="1" Margin="0,16,0,0">
                        <TextBlock Text="NAVIGATION" Foreground="Black"
                                   FontSize="15" FontWeight="Bold" Margin="57,0,0,16" />
                        <Button Content="Search Files"
                                Style="{Binding IsSearchActive, Converter={StaticResource NavStyleConverter}}"
                                Command="{Binding NavigateSearchCommand}" />
                        <Button Content="User Management"
                                Style="{StaticResource NavButton}"
                                Command="{Binding NavigateUsersCommand}"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}" />
                        <Button Content="Access Logs"
                                Style="{StaticResource NavButton}"
                                Command="{Binding NavigateLogsCommand}"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}" />
                        <Button Content="Settings"
                                Style="{StaticResource NavButton}"
                                Command="{Binding NavigateSettingsCommand}"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}" />

                        <!-- Theme Toggle separator -->
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="14,16,14,8" />

                        <!-- Theme Toggle Button -->
                        <!--<Button Command="{Binding ToggleThemeCommand}"
                                Style="{StaticResource NavButton}"
                                ToolTip="{Binding ThemeLabel}">
                            <StackPanel Orientation="Horizontal">
                                -->
                        <!-- Toggle track -->
                        <!--
                                <Border Width="40" Height="22" CornerRadius="11"
                                        VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="False">
                                                    <Setter Property="Background" Value="{StaticResource BorderBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    -->
                        <!-- Thumb -->
                        <!--
                                    <Border Width="16" Height="16" CornerRadius="8"
                                            Background="White" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="HorizontalAlignment" Value="Right" />
                                                <Setter Property="Margin" Value="0,0,3,0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="False">
                                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                                        <Setter Property="Margin" Value="3,0,0,0" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </Border>
                                <TextBlock Text="{Binding ThemeLabel}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>-->
                    </StackPanel>

                    <!-- User Panel -->
                    <Border Grid.Row="2" Margin="12,0,12,16" Padding="12"
                            Background="{StaticResource BackgroundWindowColor}"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding CurrentUserDisplay}"
                                       Margin="0,7,0,0"
                                       Foreground="Black"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap" />
                            <!--<Button Grid.Column="1" Content="Logout" ToolTip="Logout"
                                   Foreground="Red"
                                    FontWeight="SemiBold"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Command="{Binding LogoutCommand}"
                                    Padding="8,4" FontSize="11" />-->

                            <Button Grid.Column="1" Content="➜] Logout" Style="{DynamicResource DangerButton}"
                            Command="{Binding LogoutCommand}" FontSize="11" Padding="9" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <ContentPresenter Grid.Column="1" Content="{Binding CurrentView}" />
        </Grid>
    </Border>
</Window>