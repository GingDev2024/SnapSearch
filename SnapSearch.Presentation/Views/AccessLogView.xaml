<UserControl x:Class="SnapSearch.Presentation.Views.AccessLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundWindowColor}" Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Access Logs" Style="{StaticResource SectionHeader}" FontSize="20" Margin="0" />
            <TextBlock Text="Monitor and review user activity within the system. Track login history, access times, and actions to ensure security and accountability."
                       TextWrapping="Wrap"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Margin="4,30,0,0" 
                       Foreground="{StaticResource TextMutedBrush}"/>

            <Button Content="Export CSV" Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Right" Command="{Binding ExportCsvCommand}" Padding="12,6" />
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="FROM" Style="{StaticResource FormLabel}"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <DatePicker Grid.Column="1" SelectedDate="{Binding FromDate}" Cursor="Hand"
                            Background="{StaticResource SurfaceLightBrush}" Foreground="Black"
                            BorderBrush="{StaticResource AccentBrush}" Grid.ColumnSpan="2" Margin="0,11,16,10" />
                <TextBlock Grid.Column="3" Text="TO" Style="{StaticResource FormLabel}"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <DatePicker Grid.Column="3" SelectedDate="{Binding ToDate}" Cursor="Hand"
                            Background="{StaticResource SurfaceLightBrush}" Foreground="Black"
                            BorderBrush="{StaticResource AccentBrush}" Grid.ColumnSpan="2" Margin="22,11,0,10" />
                <TextBox Grid.Column="6" Style="{StaticResource SearchTextBox}"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="8" Content="Load" Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoadLogsCommand}" Padding="16,8" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid Style="{StaticResource StyledDataGrid}"
                      ColumnHeaderStyle="{StaticResource DataGridColumnHeader}"
                      ItemsSource="{Binding Logs}"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time"
                                        Binding="{Binding AccessedAt, StringFormat='{}{0:MM/dd/yyyy hh:mm tt}'}" Width="180" CanUserSort="True" />
                    <DataGridTextColumn Header="User"       Binding="{Binding Username}"      Width="120" CanUserSort="True" />
                    <DataGridTextColumn Header="Action"     Binding="{Binding Action}"         Width="110" CanUserSort="True" />
                    <DataGridTextColumn Header="Keyword"    Binding="{Binding SearchKeyword}"  Width="130" CanUserSort="True" />
                    <DataGridTextColumn Header="IP Address" Binding="{Binding IpAddress}"      Width="120" CanUserSort="True" />
                    <DataGridTextColumn Header="MAC Address" Binding="{Binding MacAddress}"    Width="140" CanUserSort="True" />
                    <DataGridTextColumn Header="File / Details" Binding="{Binding Details}"   Width="*" CanUserSort="True" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Padding="0,8,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusText}" />
                <ProgressBar HorizontalAlignment="Center" Width="728"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             Background="Transparent" Foreground="{StaticResource SuccessBrush}" Margin="0,-153,0,160" />
            </Grid>
        </Border>
    </Grid>
</UserControl>